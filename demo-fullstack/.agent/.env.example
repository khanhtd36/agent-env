# Copy to .agent/.env and edit as needed.

# Optional explicit project name. If unset, defaults to the repo folder name.
AGENT_PROJECT_NAME=

AGENT_IMAGE_NAME=agent-workspace:latest
AGENT_DIND_IMAGE_NAME=agent-dind:latest
AGENT_SYNC_SECRETS_MODE=overwrite

# Comma-separated host:port mappings published on the outer dind container.
AGENT_PROJECT_PORTS=

# Optional additional docker run args.
AGENT_WORKSPACE_RUN_ARGS=
AGENT_DIND_RUN_ARGS=

# App/browser helpers.
AGENT_APP_UP_CMD='docker compose up --build -d'
AGENT_APP_DOWN_CMD='docker compose down'
AGENT_APP_LOGS_CMD='docker compose logs -f'
AGENT_APP_STATUS_CMD='docker compose ps'

# If unset, agent-browser-test uses the first published port on the repo dind host.
AGENT_BROWSER_TEST_URL=
